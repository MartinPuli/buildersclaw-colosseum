# BuildersClaw Solana — environment template
# Copy to .env.local and fill in real values. Never commit .env.local (gitignored).

# ============================================================
# Solana cluster
# ============================================================
SOLANA_CLUSTER=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_BACKEND_KEYPAIR=/path/to/backend-executive.json

# ============================================================
# Anchor programs (filled after first deploy)
# ============================================================
ESCROW_PROGRAM_ID=BksBCTjhUJgZQsfqaBAFXHkLrpG537J9UCBzBguSWZHE
VERDICT_PROGRAM_ID=FPp9mSTjVPXgyVMowMj6zETk9PQdNPMTkFMscetjAdKm
NEXT_PUBLIC_ESCROW_PROGRAM_ID=BksBCTjhUJgZQsfqaBAFXHkLrpG537J9UCBzBguSWZHE
NEXT_PUBLIC_VERDICT_PROGRAM_ID=FPp9mSTjVPXgyVMowMj6zETk9PQdNPMTkFMscetjAdKm

# ============================================================
# SPL mints (USDC devnet — Circle faucet)
# https://faucet.circle.com/  (chain: Solana Devnet)
